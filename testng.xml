<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="ECommerce Automation Suite" verbose="1" parallel="false">

    <!-- ═══════════════════════════════════════════ -->
    <!-- Chrome Tests                                -->
    <!-- ═══════════════════════════════════════════ -->
    <test name="Chrome - Search Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.SearchTest"/>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Firefox Tests                               -->
    <!-- ═══════════════════════════════════════════ -->
    <test name="Firefox - Search Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.SearchTest"/>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Edge Tests                                  -->
    <!-- ═══════════════════════════════════════════ -->
    <test name="Edge - Search Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.SearchTest"/>
        </classes>
    </test>

</suite>
